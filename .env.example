# LLM
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# PostgreSQL
POSTGRES_USER=ara
POSTGRES_PASSWORD=ara_secret
POSTGRES_DB=ara_db
DATABASE_URL=postgresql+asyncpg://ara:ara_secret@localhost:5432/ara_db

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=research_papers

# Embedding & Reranker (HuggingFace model IDs)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

# Self-improvement thresholds
FAITHFULNESS_THRESHOLD=0.7
LAMBDA_COST=0.3
LAMBDA_LATENCY=0.1

# Constraints
MAX_LATENCY_SECONDS=15.0
